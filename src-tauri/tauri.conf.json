{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "improvie",
  "version": "0.7.1",
  "identifier": "github.improvie.improvie",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build",
    "features": [
      "include"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "improvie",
        "label": "main"
      }
    ],
    "security": {
      "csp": "script-src 'unsafe-eval';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "shortDescription": "A Tauri app to 'improve like the movie' — helping you organize local media and create playlists easily.",
    "copyright": "Copyright © 2025 improvie",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "publisher": "improvie",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../licenses/"
    ]
  }
}
